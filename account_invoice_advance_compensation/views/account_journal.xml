<odoo>
    <record id="view_account_journal_form_inherit" model="ir.ui.view">
        <field name="name">account.journal.form.inherit.advance</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='advanced_settings']" position="after">
                <page
                    name="advance_settings"
                    string="Advance Settings"
                    invisible="type != 'general'"
                >
                    <group>
                        <field
                            name="is_advance_journal"
                            string="Is Advance Journal"
                            help="Mark this journal for advance payment compensation"
                        />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
